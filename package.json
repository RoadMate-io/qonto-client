{
  "name": "@roadmate-io/qonto-client",
  "version": "0.1.7",
  "description": "TypeScript client library for the Qonto Business API",
  "keywords": [
    "qonto",
    "qonto-api",
    "banking",
    "fintech",
    "typescript",
    "api-client"
  ],
  "author": "RoadMate",
  "homepage": "https://roadmate.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/roadmate-io/qonto-client.git"
  },
  "bugs": {
    "url": "https://github.com/roadmate-io/qonto-client/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc",
    "dev": "ts-node src/index.ts",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run",
    "artifactregistry-login": "npx google-artifactregistry-auth",
    "publish:gcp": "npm publish",
    "publish:npm": "npm publish --@roadmate-io:registry=https://registry.npmjs.org --access public",
    "update": "npm test && npm run build && npm run artifactregistry-login && npm run bump && npm run publish:gcp && npm run publish:npm",
    "bump": "node ./package-bump.mjs"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "axios-mock-adapter": "^2.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.5"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  }
}
